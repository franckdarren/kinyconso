# ─────────────────────────────────────────────────────────────────────────────
# KinyConso — Variables d'environnement
# Copier ce fichier en `.env.local` et remplir les valeurs.
# Ne jamais commiter `.env.local` ni aucune clé secrète.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (https://supabase.com) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER ONLY — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=

# Connexion directe Postgres (Drizzle / migrations)
DATABASE_URL=

# ── PVIT (https://pvit.ga) ───────────────────────────────────────────────────
# URL racine de l'API PVIT (sandbox ou production)
PVIT_BASE_URL=https://api.pvit.ga
PVIT_URL_CODE=
PVIT_OPERATION_ACCOUNT_CODE=
# SERVER ONLY
PVIT_API_PASSWORD=
PVIT_CALLBACK_URL_CODE=
# Défense en profondeur du webhook (optionnel) : liste d'IP autorisées
# séparées par des virgules. Vide ⇒ pas de filtrage IP.
PVIT_CALLBACK_ALLOWED_IPS=
# Secret HMAC-SHA256 du webhook (optionnel mais recommandé si PVIT le supporte).
# Si défini, le header `x-pvit-signature` (hex) est exigé et vérifié.
# SERVER ONLY. La sécurité ne repose PAS uniquement dessus : le statut est
# systématiquement re-vérifié côté serveur via l'API PVIT authentifiée.
PVIT_CALLBACK_HMAC_SECRET=

# ── Firebase Cloud Messaging ─────────────────────────────────────────────────
# Config Web Firebase (Project settings → General → Your apps → SDK setup)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Clé VAPID Web Push (Project settings → Cloud Messaging → Web configuration)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Service account JSON pour envoi FCM HTTP v1 (Project settings → Service accounts)
# SERVER ONLY — ne jamais exposer côté client.
# La private key contient des `\n` littéraux ; on les remplace au runtime.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Cron Vercel ──────────────────────────────────────────────────────────────
# SERVER ONLY — secret partagé pour authentifier les appels cron
CRON_SECRET=

# ── Sentry (https://sentry.io) ───────────────────────────────────────────────
# DSN public (peut être exposé côté client)
NEXT_PUBLIC_SENTRY_DSN=
# Org et projet Sentry pour l'upload des source maps (build uniquement)
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token Sentry pour l'upload des source maps (SERVER / CI ONLY)
SENTRY_AUTH_TOKEN=

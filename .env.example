# ─────────────────────────────────────────────────────────────────────────────
# KinyConso — Variables d'environnement
# Copier ce fichier en `.env.local` et remplir les valeurs.
# Ne jamais commiter `.env.local` ni aucune clé secrète.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (https://supabase.com) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER ONLY — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=

# Connexion directe Postgres (Drizzle / migrations)
DATABASE_URL=

# ── PVIT (https://pvit.ga) ───────────────────────────────────────────────────
# URL racine de l'API PVIT (sandbox ou production)
PVIT_BASE_URL=https://api.pvit.ga
PVIT_URL_CODE=
PVIT_OPERATION_ACCOUNT_CODE=
# SERVER ONLY
PVIT_API_PASSWORD=
PVIT_CALLBACK_URL_CODE=

# ── Firebase Cloud Messaging ─────────────────────────────────────────────────
# Config Web Firebase (Project settings → General → Your apps → SDK setup)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Clé VAPID Web Push (Project settings → Cloud Messaging → Web configuration)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Service account JSON pour envoi FCM HTTP v1 (Project settings → Service accounts)
# SERVER ONLY — ne jamais exposer côté client.
# La private key contient des `\n` littéraux ; on les remplace au runtime.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Cron Vercel ──────────────────────────────────────────────────────────────
# SERVER ONLY — secret partagé pour authentifier les appels cron
CRON_SECRET=

# ── Sentry (https://sentry.io) ───────────────────────────────────────────────
# DSN public (peut être exposé côté client)
NEXT_PUBLIC_SENTRY_DSN=
# Org et projet Sentry pour l'upload des source maps (build uniquement)
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token Sentry pour l'upload des source maps (SERVER / CI ONLY)
SENTRY_AUTH_TOKEN=
